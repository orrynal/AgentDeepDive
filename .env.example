# AgentDeepDive Environment Configuration
# Copy to .env and fill in your values

# ── LLM API Keys ─────────────────────────────────────
AGENTDEEP_LITELLM_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AGENTDEEP_AGNES_API_KEY=
AGENTDEEP_AGNES_DEFAULT_MODEL=agnes-2.0-flash
AGENTDEEP_UX_VISUAL_MODEL=agnes-image-2.1-flash

# ── Infrastructure (defaults work with docker-compose) ─
AGENTDEEP_POSTGRES_HOST=localhost
AGENTDEEP_POSTGRES_PORT=5432
AGENTDEEP_POSTGRES_DB=agentdeep
AGENTDEEP_POSTGRES_USER=agentdeep
AGENTDEEP_POSTGRES_PASSWORD=agentdeep_dev_2026

AGENTDEEP_REDIS_HOST=localhost
AGENTDEEP_REDIS_PORT=6379

AGENTDEEP_MILVUS_HOST=localhost
AGENTDEEP_MILVUS_PORT=19530

# ── Budget ───────────────────────────────────────────
AGENTDEEP_MONTHLY_BUDGET_USD=500.0
AGENTDEEP_PER_TASK_BUDGET_USD=2.0

# ── Observability ────────────────────────────────────
AGENTDEEP_OTLP_ENDPOINT=http://localhost:4317
AGENTDEEP_ENABLE_TRACING=true

AGENTDEEP_DEBUG=true
AGENTDEEP_LOG_LEVEL=INFO

# ── DeepSeek API Keys ─────────────────────────────────
DEEPSEEK_API_KEY=
